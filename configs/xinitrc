#!/bin/sh

wal.sh &
dunst &
xcompmgr &

switch\
    -i\
    'pactl subscribe'\
    'acpi_listen'\
    'udevadm monitor --udev --property'\
    'time.sh'\
    -o\
    'statusbar.awk'\
    'lowbat.awk'\
    -r\
    1-1 2-1 3-1 4-1\
    1-2 2-2 3-2 4-2 &

# Turn X11 off bell.
xset -b

# Levantar bus de usuario dbus.
source /etc/X11/xinit/xinitrc.d/80-dbus.sh

# Gnome keyring se inicializa de la siguiente manera:
#
# 1. El modulo de PAM ejecuta gnome-keyring-daemon con --login lo que permite desbloquear el keyring del usuario, archivos internos de gnome-keyring que estan encriptados, al logearse con elogind.
# 2. Se settea GNOME_KEYRING_CONTROL a un socket unix para IPC (no dbus), en general lo hace el modulo de PAM pero no funciona en artix.
# 3. Se llama a gnome-keyring-daemon con --start lo que inicializa el deamon que expone en dbus.

# Setear variable de entorno GNOME_KEYRING_CONTROL, el modulo de pam lo deberia hacer pero no funciona.
export GNOME_KEYRING_CONTROL=/run/user/$(id -u)/keyring

# Inicializar daemon de keyring creado por pam, requiere variable GNOME_KEYRING_CONTROL y SSH_AUTH_SOCK.
gnome-keyring-daemon --start --components=secrets

exec /usr/local/src/dwm/dwm
