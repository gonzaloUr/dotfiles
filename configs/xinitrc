#!/bin/sh

wal.sh
dunst &
xcompmgr &

switch\
    -i\
    'pactl subscribe'\
    'acpi_listen'\
    'udevadm monitor --udev --property'\
    'time.sh'\
    -o\
    'statusbar.awk'\
    'lowbat.awk'\
    -r\
    1-1 2-1 3-1 4-1\
    1-2 2-2 3-2 4-2 &

# Turn X11 off bell.
xset -b

# Levantar bus de usuario dbus.
source /etc/X11/xinit/xinitrc.d/80-dbus.sh

# Launch dwm.
exec /usr/local/src/dwm/dwm
